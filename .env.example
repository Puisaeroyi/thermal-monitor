# =============================================================================
# THERMAL MONITOR - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and configure for your deployment:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# DEPLOYMENT MODE
# -----------------------------------------------------------------------------
# Set to "seed" for TEST/DEV server - includes sample cameras + readings
# Leave empty or comment out for PRODUCTION - clean schema, no fake data
# -----------------------------------------------------------------------------
APP_MODE=seed

# -----------------------------------------------------------------------------
# DATABASE (Internal Docker Network)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@db:5432/thermal_monitor"

# -----------------------------------------------------------------------------
# CAMERA SECURITY
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
# Required for encrypting camera passwords in database
# -----------------------------------------------------------------------------
CAMERA_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# API SECURITY (OPTIONAL)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 16
# Used for x-collector-secret header authentication
# Leave empty to disable (development mode)
# -----------------------------------------------------------------------------
COLLECTOR_SECRET=

# -----------------------------------------------------------------------------
# EMAIL NOTIFICATIONS (OPTIONAL)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_EMAIL_TO=
