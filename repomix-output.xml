          </SelectContent>
        </Select>
      </div>

      {/* Status */}
      <div className="flex flex-col gap-1 min-w-[160px]">
        <Label>Status</Label>
        <Select value={filters.acknowledged} onValueChange={(v) => update("acknowledged", v)}>
